{
	"name": "speech-code-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "dist-electron/main.cjs",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:web": "vite build",
		"build:electron": "node scripts/build-electron.mjs",
		"dev:electron": "npm run build:electron && concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
		"build:desktop": "npm run build:web && npm run build:electron && powershell -ExecutionPolicy Bypass -File ../speech-code-api/scripts/build-desktop-api.ps1 && electron-builder --config electron-builder.yml",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/vite": "^4.3.1",
		"concurrently": "^10.0.3",
		"cross-env": "^10.1.0",
		"daisyui": "^5.5.23",
		"electron": "^33.4.11",
		"electron-builder": "^26.15.3",
		"esbuild": "^0.28.1",
		"svelte": "^5.30.0",
		"svelte-check": "^4.2.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.8.0",
		"vite": "^6.3.0",
		"wait-on": "^9.0.10"
	}
}
